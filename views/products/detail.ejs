<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chi tiết sản phẩm</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        body {
            background: linear-gradient(135deg, #f5f7fa 0%, #dce4f7 100%);
            min-height: 100vh;
        }
        .product-detail-card {
            background: white;
            border-radius: 20px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.1);
            overflow: hidden;
        }
        .product-detail-image {
            min-height: 450px;
            object-fit: cover;
            width: 100%;
        }
        .badge-category {
            background: linear-gradient(135deg, #667eea, #764ba2);
            color: white;
            border-radius: 50px;
            padding: 0.45em 0.9em;
        }
        .btn-secondary {
            border-radius: 30px;
            font-weight: bold;
            background-color: #6c757d;
            border: none;
        }
        .btn-primary {
            border-radius: 30px;
            border: none;
            font-weight: 600;
        }
        .btn-primary:hover {
            transform: translateY(-1px);
            transition: transform 0.2s ease;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-light sticky-top" style="background: rgba(255,255,255,0.9); backdrop-filter: blur(10px);">
        <div class="container">
            <a class="navbar-brand fw-bold text-primary" href="/products"><i class="fas fa-store me-2"></i>Cửa hàng quần áo</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item"><a class="nav-link" href="/products">Trang chủ</a></li>
                </ul>
                <div class="d-flex align-items-center">
                    <% if (currentUser) { %>
                        <span class="me-3 text-dark">Xin chào, <strong class="text-primary"><%= currentUser %></strong>!</span>
                        <a href="/users/logout" class="btn btn-outline-danger btn-sm">Đăng xuất</a>
                    <% } else { %>
                        <a href="/users/login" class="btn btn-outline-primary btn-sm me-2">Đăng nhập</a>
                        <a href="/users/register" class="btn btn-primary btn-sm">Đăng ký</a>
                    <% } %>
                </div>
            </div>
        </div>
    </nav>

    <div class="container my-5">
        <a href="/products" class="btn btn-secondary mb-4"><i class="fas fa-arrow-left me-2"></i>Quay lại</a>

        <div class="product-detail-card row g-0">
            <div class="col-lg-6">
                <img src="<%= product.image && product.image !== 'default.jpg' ? product.image : 'https://via.placeholder.com/800x900?text=No+Image' %>" class="img-fluid product-detail-image" alt="<%= product.name %>">
            </div>
            <div class="col-lg-6 p-4 p-lg-5">
                <h1 class="mb-3"><%= product.name %></h1>
                <h2 class="text-danger mb-3">$<%= product.price %>.00</h2>
                <p><span class="badge-category"><i class="fas fa-tag me-1"></i><%= product.category ? product.category.name : 'Chưa phân loại' %></span></p>
                <hr>
                <h5>Mô tả sản phẩm</h5>
                <p class="mb-4"><%= product.description || 'Chưa có mô tả cho sản phẩm này.' %></p>
                <div class="d-flex flex-wrap gap-2">
                    <button class="btn btn-primary btn-lg"><i class="fas fa-shopping-cart me-2"></i>Thêm vào giỏ hàng</button>
                    <a href="/products/<%= product._id %>/edit" class="btn btn-outline-warning btn-lg"><i class="fas fa-edit me-2"></i>Sửa</a>
                    <form action="/products/<%= product._id %>?_method=DELETE" method="POST" onsubmit="return confirm('Bạn có chắc chắn muốn xóa sản phẩm này?')">
                        <button type="submit" class="btn btn-outline-danger btn-lg"><i class="fas fa-trash me-2"></i>Xóa</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>