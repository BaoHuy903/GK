<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Chi tiết sản phẩm</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <nav class="navbar navbar-light bg-light mb-4 shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/products">🏠 Trang Chủ</a>
            <div class="d-flex ms-auto align-items-center">
                <% if (currentUser) { %>
                    <span class="me-3">Xin chào, <strong class="text-primary"><%= currentUser %></strong>!</span>
                    <a href="/users/logout" class="btn btn-sm btn-outline-danger">Đăng xuất</a>
                <% } else { %>
                    <a href="/users/login" class="btn btn-sm btn-outline-primary">Đăng nhập</a>
                <% } %>
            </div>
        </div>
    </nav>
    <div class="container mt-5">
        <a href="/products" class="btn btn-secondary mb-3">&larr; Quay lại</a>
        <div class="row">
            <div class="col-md-6">
                <img src="<%= product.image && product.image !== 'default.jpg' ? product.image : 'https://via.placeholder.com/500x600?text=No+Image' %>" class="img-fluid rounded" alt="<%= product.name %>">
            </div>
            <div class="col-md-6">
                <h1><%= product.name %></h1>
                <h3 class="text-danger">$<%= product.price %>.00</h3>
                <hr>
                <p><strong>Danh mục:</strong> <%= product.category ? product.category.name : 'Chưa phân loại' %></p>
                <p><strong>Mô tả:</strong> <%= product.description || 'Chưa có mô tả cho sản phẩm này.' %></p>
                <button class="btn btn-primary btn-lg mt-3">Thêm vào giỏ hàng</button>
            </div>
        </div>
    </div>
</body>
</html>